    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const data = $input.first().json;\nconst errors = [];\nconst required = ['full_name', 'personal_email', 'role', 'department', 'manager_email', 'start_date', 'timezone'];\n\nfor (const field of required) {\n  if (!data[field] || String(data[field]).trim() === '') {\n    errors.push(`Missing required field: ${field}`);\n  }\n}\n\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nif (data.personal_email && !emailRegex.test(data.personal_email)) {\n  errors.push('personal_email is not a valid email address');\n}\nif (data.manager_email && !emailRegex.test(data.manager_email)) {\n  errors.push('manager_email is not a valid email address');\n}\n\nif (data.start_date) {\n  const startDate = DateTime.fromISO(String(data.start_date));\n  if (!startDate.isValid) {\n    errors.push('start_date is not a valid ISO date (expected YYYY-MM-DD)');\n  } else if (startDate.startOf('day') < DateTime.now().startOf('day')) {\n    errors.push('start_date must be today or in the future');\n  }\n}\n\nif (data.timezone) {\n  const tzCheck = DateTime.now().setZone(data.timezone);\n  if (!tzCheck.isValid) {\n    errors.push('timezone is not a valid IANA timezone, e.g. Asia/Riyadh');\n  }\n}\n\nreturn [{\n  json: {\n    ...data,\n    valid: errors.length === 0,\n    errors,\n  }\n}];"
      },
