    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const target = ($('Validate Input').first().json.personal_email || '').toLowerCase().trim();\nconst rows = $input.all();\nconst match = rows.find(r => (r.json.personal_email || '').toLowerCase().trim() === target);\n\nreturn [{\n  json: {\n    ...$('Validate Input').first().json,\n    already_exists: !!match,\n  }\n}];"
      },
